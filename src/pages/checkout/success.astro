---
import SiteLayout from '../../layouts/SiteLayout.astro';
---

<SiteLayout
  title="Checkout Complete | Rustzen"
  description="Your Rustzen checkout has completed."
>
  <main class="checkout-success">
    <section>
      <p class="eyebrow">Checkout complete</p>
      <h1>Open Zen Clear and activate Pro.</h1>
      <p>
        Your annual Pro subscription is active. Use the license key from your Creem receipt in
        Zen Clear Settings.
      </p>
      <a class="button primary" href="/zen-clear">Back to Zen Clear</a>
    </section>
  </main>
</SiteLayout>

<style>
  .checkout-success {
    min-height: calc(100svh - 67px);
    display: grid;
    place-items: center;
    padding: clamp(54px, 9vw, 128px) clamp(20px, 5vw, 72px);
    background: linear-gradient(135deg, #ffffff 0%, var(--clear-panel) 58%, var(--paper) 100%);
  }

  .checkout-success section {
    max-width: 760px;
  }

  .checkout-success h1 {
    margin: 0;
    color: var(--charcoal);
    font-size: clamp(3rem, 8vw, 7rem);
    line-height: 0.95;
    letter-spacing: 0;
  }

  .checkout-success p:not(.eyebrow) {
    margin: 26px 0 30px;
    color: var(--muted);
    font-size: clamp(1.1rem, 2vw, 1.35rem);
  }
</style>
