---
import SiteLayout from '../layouts/SiteLayout.astro';
import { tools } from '../data/tools';
import { getAllPosts } from '../utils/posts';

const posts = await getAllPosts();
const latestPosts = posts.slice(0, 3);
---

<SiteLayout
  title="Rustzen | Zen Clear and Clipboard"
  description="Rustzen builds focused desktop apps for developers and productivity users, starting with safe cleaning and clipboard history."
>
  <main>
    <section class="hero">
      <div class="hero-visual" aria-hidden="true">
        <div class="terminal-panel reveal">
          <span class="dot clear"></span>
          <span class="dot clipboard"></span>
          <span class="dot warm"></span>
          <p class="terminal-title">Zen Clear</p>
          <pre><code>scan developer caches
preview disk pressure
choose cleanup scope
keep every action explicit</code></pre>
        </div>
        <div class="clipboard-panel reveal">
          <p>Clipboard</p>
          <span>Text and image history stays private on device.</span>
        </div>
      </div>
      <div class="hero-copy reveal">
        <p class="eyebrow">Rustzen macOS apps</p>
        <h1>Zen Clear and Clipboard for macOS.</h1>
        <p>
          A bright, local-first workspace for safe developer cleanup and
          private clipboard history.
        </p>
        <div class="button-row">
          <a class="button primary" href="/zen-clear">Open Zen Clear</a>
          <a class="button secondary" href="/clipboard">Open Clipboard</a>
        </div>
      </div>
    </section>

    <section class="tools-section" aria-labelledby="tools-title">
      <div class="section-heading">
        <p class="eyebrow">Zen Clear / Clipboard</p>
        <h2 id="tools-title">Two desktop tools, one local-first principle.</h2>
      </div>
      <div class="tool-lines">
        {
          tools.map((tool) => (
            <a class={`tool-line ${tool.accent}`} href={tool.href}>
              <div>
                <p class="tool-status">{tool.status}</p>
                <h3>{tool.name}</h3>
                <p>{tool.description}</p>
              </div>
              <span aria-hidden="true">View</span>
            </a>
          ))
        }
      </div>
    </section>

    <section class="principle-section">
      <div>
        <p class="eyebrow">Product direction</p>
        <h2>Readable workflows before broad automation.</h2>
      </div>
      <p>
        Zen Clear focuses on inspectable cleanup for developer environments.
        Clipboard focuses on private, searchable history. Both tools keep
        the user close to the data and make destructive actions explicit.
      </p>
    </section>

    <section class="blog-strip" aria-labelledby="blog-title">
      <div class="section-heading">
        <p class="eyebrow">Blog</p>
        <h2 id="blog-title">Latest notes from the Rustzen ecosystem.</h2>
      </div>
      <div class="latest-posts">
        {
          latestPosts.map((post) => (
            <a href={`/blog/${post.id}`} class="latest-post">
              <time datetime={post.data.pubDate.toISOString()}>
                {post.data.pubDate.toLocaleDateString('en', {
                  year: 'numeric',
                  month: 'short',
                  day: 'numeric',
                })}
              </time>
              <h3>{post.data.title}</h3>
              <p>{post.data.description}</p>
            </a>
          ))
        }
      </div>
      <a class="button secondary" href="/blog">Open blog</a>
    </section>
  </main>
</SiteLayout>

<style>
  .hero {
    display: grid;
    min-height: calc(100svh - 67px);
    grid-template-columns: minmax(0, 1fr) minmax(360px, 640px);
    background:
      radial-gradient(circle at 20% 32%, rgb(211 231 253 / 0.88), transparent 34%),
      radial-gradient(circle at 84% 26%, rgb(219 236 225 / 0.82), transparent 32%),
      linear-gradient(135deg, #ffffff 0%, var(--clear-panel) 52%, var(--paper) 100%);
    color: var(--charcoal);
  }

  .hero-copy {
    align-self: center;
    max-width: 720px;
    padding: clamp(54px, 8vw, 104px) clamp(22px, 5vw, 72px);
  }

  .hero h1 {
    max-width: 12ch;
    margin: 0;
    font-size: clamp(3.4rem, 7.4vw, 6.8rem);
    line-height: 0.94;
    letter-spacing: 0;
    overflow-wrap: anywhere;
  }

  .hero-copy > p:not(.eyebrow) {
    max-width: 560px;
    margin: 26px 0 34px;
    color: var(--muted);
    font-size: clamp(1.1rem, 2vw, 1.35rem);
  }

  .hero .button.primary {
    color: #ffffff;
    background: linear-gradient(135deg, var(--clipboard-teal), #168c83);
  }

  .hero .button.secondary {
    color: var(--charcoal);
    border-color: rgb(119 168 247 / 0.38);
  }

  .hero-visual {
    position: relative;
    display: grid;
    place-items: center;
    min-height: 420px;
    padding: clamp(24px, 5vw, 72px);
    overflow: hidden;
  }

  .hero-visual::before {
    position: absolute;
    inset: 12%;
    content: '';
    background:
      linear-gradient(rgb(119 168 247 / 0.18) 1px, transparent 1px),
      linear-gradient(90deg, rgb(119 168 247 / 0.18) 1px, transparent 1px);
    background-size: 38px 38px;
    mask-image: radial-gradient(circle, black 0%, transparent 72%);
  }

  .terminal-panel {
    position: relative;
    width: min(100%, 520px);
    padding: 24px;
    color: var(--charcoal);
    background: rgb(255 255 255 / 0.72);
    border: 1px solid rgb(119 168 247 / 0.32);
    border-radius: 8px;
    box-shadow:
      0 24px 80px rgb(119 168 247 / 0.24),
      0 1px 0 rgb(255 255 255 / 0.9) inset;
    backdrop-filter: blur(18px);
  }

  .dot {
    display: inline-block;
    width: 10px;
    height: 10px;
    margin-right: 8px;
    border-radius: 50%;
  }

  .dot.clear {
    background: var(--clear-blue-deep);
  }

  .dot.clipboard {
    background: var(--clipboard-teal);
  }

  .dot.warm {
    background: var(--clipboard-gold);
  }

  .terminal-title {
    margin: 28px 0 14px;
    color: var(--muted);
    font-size: 0.84rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
  }

  pre {
    margin: 0;
    white-space: pre-wrap;
    font-size: clamp(1.2rem, 2.2vw, 1.7rem);
    line-height: 1.55;
  }

  .clipboard-panel {
    position: absolute;
    right: clamp(16px, 5vw, 72px);
    bottom: clamp(20px, 8vw, 88px);
    width: min(320px, 72%);
    padding: 20px;
    background: rgb(255 255 255 / 0.78);
    border: 1px solid rgb(15 118 110 / 0.24);
    border-radius: 8px;
    box-shadow: 0 18px 52px rgb(15 118 110 / 0.14);
    backdrop-filter: blur(18px);
    animation-delay: 120ms;
  }

  .clipboard-panel p {
    margin: 0 0 8px;
    color: var(--clipboard-teal);
    font-size: 1.15rem;
    font-weight: 700;
  }

  .clipboard-panel span {
    color: var(--muted);
    font-size: 0.95rem;
  }

  .tools-section,
  .blog-strip {
    padding: clamp(64px, 10vw, 124px) clamp(20px, 5vw, 72px);
  }

  .section-heading {
    max-width: 760px;
    margin-bottom: 34px;
  }

  .section-heading h2,
  .principle-section h2 {
    margin: 0;
    color: var(--charcoal);
    font-size: clamp(2.1rem, 5vw, 4.4rem);
    line-height: 1;
    letter-spacing: 0;
  }

  .tool-lines {
    display: grid;
    gap: 1px;
    background: rgb(100 112 134 / 0.16);
  }

  .tool-line {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 28px;
    align-items: center;
    min-height: 220px;
    padding: clamp(24px, 5vw, 54px);
    background: rgb(255 255 255 / 0.74);
    transition:
      background 180ms ease,
      box-shadow 180ms ease,
      color 180ms ease;
  }

  .tool-line:hover {
    background: rgb(255 255 255 / 0.94);
    box-shadow: 0 16px 42px rgb(96 112 138 / 0.12);
  }

  .tool-status {
    margin: 0 0 16px;
    color: var(--accent);
    font-size: 0.9rem;
    font-weight: 700;
  }

  .tool-line.clear .tool-status {
    color: #4c8de9;
  }

  .tool-line.clipboard .tool-status {
    color: var(--clipboard-teal);
  }

  .tool-line h3 {
    margin: 0;
    font-size: clamp(2rem, 4vw, 3.8rem);
    line-height: 1;
  }

  .tool-line p:last-child {
    max-width: 780px;
    margin: 18px 0 0;
    color: var(--muted);
    font-size: 1.08rem;
  }

  .tool-line span {
    font-weight: 700;
    color: var(--accent);
  }

  .principle-section {
    display: grid;
    grid-template-columns: minmax(260px, 0.75fr) minmax(0, 1fr);
    gap: clamp(28px, 6vw, 88px);
    align-items: end;
    padding: clamp(64px, 10vw, 124px) clamp(20px, 5vw, 72px);
    background: var(--surface);
  }

  .principle-section > p {
    margin: 0;
    color: var(--muted);
    font-size: clamp(1.2rem, 2.4vw, 1.7rem);
    line-height: 1.45;
  }

  .latest-posts {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1px;
    margin-bottom: 28px;
    background: rgb(100 112 134 / 0.16);
  }

  .latest-post {
    min-height: 260px;
    padding: 28px;
    background: rgb(255 255 255 / 0.74);
    transition:
      transform 180ms ease,
      background 180ms ease;
  }

  .latest-post:hover {
    transform: translateY(-3px);
    background: var(--surface);
  }

  .latest-post time {
    color: var(--clipboard-teal);
    font-size: 0.88rem;
    font-weight: 700;
  }

  .latest-post h3 {
    margin: 18px 0 14px;
    font-size: 1.35rem;
    line-height: 1.18;
  }

  .latest-post p {
    margin: 0;
    color: var(--muted);
    font-size: 0.98rem;
  }

  @media (max-width: 920px) {
    .hero,
    .principle-section,
    .latest-posts {
      grid-template-columns: 1fr;
    }

    .hero-copy {
      order: -1;
    }
  }

  @media (max-width: 640px) {
    .hero h1 {
      font-size: 3.4rem;
    }

    .tool-line {
      grid-template-columns: 1fr;
    }
  }
</style>
